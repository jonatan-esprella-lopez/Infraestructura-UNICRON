NODE_ENV=production
API_NAME=unicron-api
API_HOST=0.0.0.0
API_PORT=4000
API_PREFIX=/api/v1
PUBLIC_API_URL=https://infraestructura-unicron-api.vercel.app
FRONTEND_URL=https://wasi.pages.dev
AGENTS_API_URL=https://casalens-agents-production.up.railway.app
CORS_ORIGINS=https://wasi.pages.dev,https://infraestructura-unicron-api.vercel.app,http://localhost:5173,http://127.0.0.1:5173

DATABASE_PROVIDER=postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
TURSO_DATABASE_URL=libsql://DATABASE.aws-us-east-1.turso.io
TURSO_AUTH_TOKEN=replace-me
REDIS_URL=

JWT_SECRET=replace-me
JWT_ISSUER=unicron-api
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
INTEGRATION_API_KEY=replace-me

RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_MS=60000
REQUEST_TIMEOUT_MS=30000

FEATURE_AI_ENABLED=true
FEATURE_AUDIT_LOGS_ENABLED=true
FEATURE_QUEUES_ENABLED=true

AI_PROVIDER=openai
AI_MODEL=gpt-5.4-mini
OPENAI_API_KEY=

MAIL_PROVIDER=console
MAIL_FROM=noreply@wasi.pages.dev
STORAGE_DRIVER=local
STORAGE_BUCKET=local
QUEUE_PREFIX=unicron
WEBSOCKET_PATH=/ws
