# DeepSeek
DEEPSEEK_API_KEY=sk-...

# Voyage embeddings (voyageai.com — 200M tokens gratis)
VOYAGE_API_KEY=pa-...

# Telegram
TELEGRAM_BOT_TOKEN=7234567890:AAH...

# Postgres (local con Docker)
DATABASE_URL=postgresql://unicron:unicron@localhost:5432/unicron

# LangSmith
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...
