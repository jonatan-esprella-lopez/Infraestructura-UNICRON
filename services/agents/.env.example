# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key

# Voyage embeddings
VOYAGE_API_KEY=your_voyage_api_key

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Postgres local with Docker
DATABASE_URL=postgresql://unicron:unicron@localhost:55432/unicron

# LangSmith (optional)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_optional
LANGSMITH_PROJECT=casalens-mvp

# Models
LEAD_MODEL=deepseek-chat
MATCH_MODEL=deepseek-chat
LEGAL_MODEL=deepseek-reasoner
